---
import EthLisbonScroll from "../components/EthLisbonScroll";
import EthuiScroll from "../components/ethui-scroll";
import FAQs from "../components/FAQs";
import Footer from "../components/footer";
import Hero from "../components/Hero";
import HighlightScroll from "../components/HighlightScroll";
import HowItWorks from "../components/HowItWorks";
import Navbar from "../components/Navbar";
import StoryScroll from "../components/StoryScroll";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Subvisual EthUI">
  <main class="relative z-10">
    <Hero client:load />
    <div id="hero-sentinel" class="h-px w-full" />

    <div class="max-w-[1920px] w-full mx-auto px-5 lg:px-20">
      <StoryScroll client:visible />
      <HowItWorks client:visible />
      <HighlightScroll client:visible />
      <EthLisbonScroll client:visible />
      <EthuiScroll client:visible />

      <div class="pt-30 lg:pt-56">
        <FAQs client:visible />
      </div>
    </div>

    <div class="pt-30 lg:pt-56 pb-10 lg:pb-20">
      <div class="max-w-[1920px] w-full mx-auto px-5 lg:px-20">
        <div id="footer-navbar-dock" class="max-w-7xl mx-auto w-full px-5 lg:px-4" />
        <Footer client:load />
      </div>
    </div>
  </main>

  <div
    id="navbar-wrapper"
    class="fixed bottom-4 lg:bottom-8 left-1/2 -translate-x-1/2 z-20 w-[calc(100%-2.5rem)] lg:w-[calc(100%-4rem)] max-w-7xl"
  >
    <div
      id="navbar-primary"
      class="opacity-0 animate-slide-up-in transition-opacity duration-300"
    >
      <Navbar client:load type="primary" />
    </div>
    <div
      id="navbar-secondary"
      class="opacity-0 pointer-events-none transition-opacity duration-300 absolute bottom-0 left-1/2 -translate-x-1/2"
    >
      <Navbar client:idle type="secondary" />
    </div>
  </div>
</Layout>

<script>
  import { initNavbar } from "../lib/navbarController";

  history.scrollRestoration = "manual";
  window.scrollTo(0, 0);

  let animationDone = false;
  const ctrl = initNavbar({ readyGate: () => animationDone });

  const sentinel = document.getElementById("hero-sentinel")!;
  const primary = document.getElementById("navbar-primary")!;

  primary.addEventListener("animationend", () => {
    animationDone = true;
    primary.style.animation = "none";
    primary.style.opacity = "1";

    const rect = sentinel.getBoundingClientRect();
    const heroVisible = rect.top > window.innerHeight;
    if (!heroVisible) {
      ctrl.applyNavbarState(true);
      ctrl.applyNavbarState(false);
    }
    ctrl.checkDock();
  });

  const heroObserver = new IntersectionObserver(
    ([entry]) => {
      if (!animationDone || ctrl.docked || ctrl.switching) return;
      ctrl.applyNavbarState(entry.boundingClientRect.top > window.innerHeight);
    },
    { threshold: 0 },
  );
  heroObserver.observe(sentinel);

  document.addEventListener("astro:before-swap", () => {
    ctrl.destroy();
    heroObserver.disconnect();
  });
</script>
